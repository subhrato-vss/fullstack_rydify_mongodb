<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head_includes') %>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            background: linear-gradient(135deg, #ffcc66, #ff9900);
            color: #333;
        }

        .dashboard {
            text-align: center;
            width: 90%;
            max-width: 1200px;
            margin: auto;
            padding: 50px 0;
        }

        .cards {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 20px;
            margin-bottom: 40px;
        }

        .card {
            width: 230px;
            background: #fff;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
            padding: 30px;
            border-radius: 15px;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            color: #333;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
        }

        .card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.2);
        }

        .stat {
            font-size: 2.5rem;
            font-weight: bold;
            color: #ff9900;
        }

        h1 {
            font-size: 3rem;
            margin-bottom: 40px;
            color: #fff;
            text-shadow: 2px 2px 10px rgba(0, 0, 0, 0.3);
        }

        h2 {
            font-size: 1.3rem;
            margin-bottom: 10px;
            color: #333;
        }

        .chart-container {
            max-width: 600px;
            margin: 0 auto;
            background: white;
            padding: 20px;
            border-radius: 15px;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
        }
    </style>
</head>
<body onload="fetchdata()">
<%- include('../partials/admin_header') %>
<div class="page-inner">
    <div class="dashboard">
        <h1>Admin Dashboard</h1>

        <div class="cards">
            <div class="card">
                <h2>Total Dealers</h2>
                <p class="stat" id="DealerCount">25</p>
            </div>
            <div class="card">
                <h2>Total Categories</h2>
                <p class="stat" id="categories">10</p>
            </div>
            <div class="card">
                <h2>Total Bookings</h2>
                <p class="stat" id="bookings">120</p>
            </div>
        </div>

        <div class="chart-container">
            <canvas id="adminChart"></canvas>
        </div>
    </div>
</div>
<%- include('../partials/footer') %>
<%- include('../partials/body_includes') %>
<script>
    async function fetchdata()
    {
        var res=await fetch('/admin/viewcategory');
        res=await res.json();
        // console.log(res.records);
        document.getElementById("categories").innerText=res.records.length;

        res=await fetch('/admin/fetchDealer');
        res=await res.json();
        document.getElementById("DealerCount").innerText=res.records.length;

        res=await fetch('/admin/fetchbooking');
        res=await res.json();
        document.getElementById("bookings").innerText=res.records.length;


        const updateStat = async (url, id) => {
            let res = await fetch(url);
            res = await res.json();
            document.getElementById(id).innerText = res.records.length;
        };

        await updateStat('/admin/viewcategory', 'categories');
        await updateStat('/admin/fetchDealers', 'DealerCount');
        await updateStat('/admin/fetchbooking', 'bookings');
    }

    const ctxAdmin = document.getElementById('adminChart').getContext('2d');
    new Chart(ctxAdmin, {
        type: 'bar',
        data: {
            labels: ['Dealers', 'Categories', 'Bookings'],
            datasets: [{
                label: 'Admin Stats',
                data: [10, 5, 30],
                backgroundColor: ['#ffcc66', '#ff9933', '#ff6600'],
                borderWidth: 1,
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false }
            },
            scales: {
                y: { beginAtZero: true }
            }
        }
    });
</script>
</body>
</html>
