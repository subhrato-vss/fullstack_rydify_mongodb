<script>
    async function AddCategory()
    {
        if($("#category").valid())
        {
            var name=document.getElementById("name").value;
            var photo=document.getElementById('photo').files[0];
            var formdata=new FormData();

            formdata.append('name',name);
            formdata.append('photo',photo);

            var res=await fetch('/admin/add_category',
                {
                    method:'POST',
                    body:formdata
                });
            res=await res.json();
            if(res.error)
            {
                Qual.errordb("Error",res.message);
            }
            else
            {

                Qual.successdb("Success",res.message);
                document.getElementById('category').reset();
                viewCategory();
            }

        }
    }
    async function viewCategory()
    {
        var res=await fetch('/admin/viewcategory');
        res=await res.json();
        var records=res.records;
        // console.log(records);
        var html=``;
        for(var x of records)
        {
            html+=`<div class="col-lg-4 col-md-6">
                <div class="service-card style3">
                    <div class="thumb">
                        <img src="${x.photo}" width="200px" style="height:200px;" alt="img">
                    </div>
                    <div class="card-details">

                        <h3 class="service-card_title h4">${x.name}</h3>`;

            html+=`<button type="button" class='as-btn style4' onclick='DeleteCategory(${x.id})'>delete</button>`;
            html+= `
                    </div>
                </div>
            </div>`;

        }
        document.getElementById("categories").innerHTML=html;
    }
    async function DeleteCategory(id)
    {
        try {
            //agar hum method type nahi denge to get se delete hoga
            var res = await fetch("/admin/delete_category/"+id,{method:'DELETE'});
            res = await res.json();
            if(res.error)
            {
                Qual.errordb("Error",res.message);
            }
            else
            {
                Qual.successdb("Success",res.message);
                viewCategory();
            }
        }
        catch (e)
        {
            Qual.errordb("Error",e.message);
        }
    }

</script>
