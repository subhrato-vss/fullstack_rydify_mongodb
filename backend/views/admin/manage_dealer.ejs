<script src="/js/email.js"></script>
<script>
    async function fetchDealers()
    {
        var res=await fetch('/admin/fetchDealer');
        res=await res.json();
        var records=res.records;
        console.log(records);
        html=``;
        for(var x of records)
        {
            html+=`<div class="col-lg-4 col-md-6">
                <div class="service-card style3">
                    <div class="thumb">
                        <img src="${x.photo}" alt="img">
                    </div>
                    <div class="card-details">

                        <h3 class="service-card_title h4">${x.name}</h3>

                        <p class=""> Email:- ${x.email}</p>
                         <p class="">Adhar Card:- ${x.adhar_card}</p>
                         <p class="">Pan Card:- ${x.pan_card}</p>
                         <p class=""> Email:- ${x.mobile}</p>
                         <p class="">Gender:- ${x.gender}</p>
                         <p class=""> Address:- ${x.address}</p>
                         <p class="">City:- ${x.city}</p>
                         <p class="service-card_text"> Status:- ${x.status}</p>`;
                        if(x.status=='Inactive')
                        {
                            html+=`<a class="line-btn" onclick="updateDealers(${x.id},'Active','${x.name}','${x.email}')">Active</a>`;
                        }
                        else
                        {
                            html+=`<a class="line-btn" onclick="updateDealers(${x.id},'Inactive','${x.name}','${x.email}')">Deactive</a>`;
                        }
            html+=`<button type="button" class='btn btn-danger offset-md-6' onclick='deleteDealer(${x.id})'>delete</button>`;
            html+= `
                    </div>
                </div>
            </div>`
        }
        document.getElementById("dealers").innerHTML=html;
    }
    async function updateDealers(id,status,name,email)
    {
        var res=await fetch('/admin/update_dealerstatus/'+id,{
            method:'PUT',
            headers:{'Content-Type':'application/json'},
            body:JSON.stringify(
                {
                    status:status
                })
        })
        res=await res.json();
        if(res.error)
        {
            Qual.errordb("Error",res.message);
        }
        else
        {

            var mailStatus="";
            if(status=='Active')
            {
                mailStatus='Approved';
            }
            else
            {
                mailStatus='Rejected';
            }
            sendMail(email,name,mailStatus);
            fetchDealers();
        }
    }
    async function deleteDealer(id)
    {
        try {
            //agar hum method type nahi denge to get se delete hoga
            var res = await fetch("/admin/delete_dealer/"+id,{method:'DELETE'});
            res = await res.json();
            if(res.error)
            {
                Qual.errordb("Error",res.message);
            }
            else
            {
                Qual.successdb("Success",res.message);
                fetchDealers();
            }
        }
        catch (e)
        {
            console.log(e.message);
        }
    }

</script>
