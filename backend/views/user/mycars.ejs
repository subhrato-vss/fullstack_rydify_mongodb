<!doctype html>
<html class="no-js" lang="zxx">

<head>
    <%-include('../partials/head_includes')%>

    <style>
        .error{
            color:red;
        }


        h2 {
            color: #222; /* Darker for contrast */
        }

        p {
            color: #444;
        }

        textarea {
            width: 100%;
            height: 80px;
            padding: 10px;
            border-radius: 5px;
            border: 1px solid #ccc;
            outline: none;
            resize: none;
            background: #f9f9f9;
            color: #222;
            font-size: 14px;
        }


        .star-rating {
            display: flex;
            flex-direction: row-reverse;
            justify-content: center;
            margin-bottom: 10px;
        }
        .star-rating input {
            display: none;
        }
        .star-rating label {
            font-size: 30px;
            color: #bbb;
            cursor: pointer;
            transition: color 0.3s;
        }
        .star-rating input:checked ~ label {
            color: goldenrod;
        }
        .star-rating label:hover,
        .star-rating label:hover ~ label {
            color: goldenrod;
        }
        .modal{
            border-radius: 100px;
        }
        .modal-body
        {
            font-family: Arial, sans-serif;
            /*background: linear-gradient(to bottom, #222, #555); !* Black to Grey gradient *!*/
            color: #fff;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 70vh;
            margin: 0;
        }
    </style>
</head>
