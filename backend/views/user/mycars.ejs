        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title fs-5" id="exampleModalLabel">Vehicle Review</h4>
                <button type="button" class="btn-danger " data-bs-dismiss="modal" aria-label="Close">X</button>
            </div>
            <div class="modal-body ">
                <input type="hidden" id="carId">
                <div class="review-container">
                    <h4 class="text-dark">Rate Us</h4>
                    <select id="rating">
                        <option value="1">1</option>
                        <option value="2">2</option>
                        <option value="3">3</option>
                        <option value="4">4</option>
                        <option value="5">5</option>
                    </select>

                    <h4 class="text-dark mt-3">Your Feedback</h4>
                    <textarea placeholder="Write your review here..." id="feedback"></textarea>
                    <button onclick='addReview()' class="btn btn-primary text-uppercase w-100" >Submit</button>
                    <button onclick="goback()" class="btn mt-3 btn-danger text-uppercase w-100">GO-BACK</button>
                </div>
            </div>

        </div>
    </div>
</div>

