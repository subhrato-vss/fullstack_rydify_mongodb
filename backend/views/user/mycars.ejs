<script>
    window.onload=function ()
    {
        fetchMycars();
    }
    async function fetchMycars()
    {
        var res=await fetch('/user/fetchMycars');
        res=await res.json();
        var records=res.records;
        console.log(records);
        var html=``;
        for(var x of records)
        {
            html+=`<div class="col-xl-3 col-lg-4 col-sm-6">
                <div class="as-product style2">
                    <div class="product-thumb-wrap">
                        <h4 class="product-title h5">${x.car.brand} ${x.car.name}</h4>
                        <div class="product-img">
                            <img src="${x.car.photo}" alt="product image">
                        </div>
                     </div>

                    <div class="product-content">
                        <h5 class="price h6">Rs. ${x.car.price}</h5>
                        <span class="year-tag">${x.car.model}</span>

                        <ul class="product-feature">
                                <li>
                                    <div class="icon"><img src="/assets/img/icon/product-feature-icon-1.svg" alt="icon"></div>
                                    ${x.car.ownerType}
                                </li>
                                <li>
                                    <div class="icon"><img src="/assets/img/icon/product-feature-icon-2.svg" alt="icon"></div>
                                    ${x.car.engineCapacity}
                                </li>
                                <li>
                                    <div class="icon"><img src="/assets/img/icon/product-feature-icon-3.svg" alt="icon"></div>
                                    ${x.car.transmissionType}
                                </li>
                                <li>
                                    <div class="icon"><img src="/assets/img/icon/product-feature-icon-4.svg" alt="icon"></div>
                                    ${x.car.fuelType}
                                </li>
                        </ul>
                        <div class="mt-2">
                                <p style="margin:0px; padding: 0px;"> Milaege: ${x.car.mileage} km/l</p>
                                <p style="margin:0px; padding: 0px;"> Km Driven: ${x.car.kmDriven} kms</p>`
                               if(x.status=='Pending')
                               {
                                   html+=`<p style="margin:0px; padding: 0px;"> Status :<span style='background-color:yellow; color: white;'> ${x.status}</span> </p>`;
                               }
                               else if(x.status=='Approved')
                               {
                                   html+=`<p style="margin:0px; padding: 0px;"> Status :<span style='background-color:blue; color: white;'> ${x.status}</span> </p>`;
                               }
                               else if(x.status=='Cancelled')
                               {
                                   html+=`<p style="margin:0px; padding: 0px;"> Status :<span style='background-color:red; color: white;'> ${x.status}</span> </p>`;
                               }
                               else
                               {
                                   html+=`<p style="margin:0px; padding: 0px;"> Status :<span style='background-color:green; color: white;'> ${x.status}</span> </p>`;
                               }
                        html+=`
                                <p style="margin:0px; padding: 0px; font-weight: bold"> Booked At : ${x.createdAt.split('T')[0]} </p>
                        </div>`
                if(x.status=='Completed')
                {
                    html+=`<button type='button' data-bs-toggle='modal' data-bs-target='#exampleModal'  class="mt-2 as-btn style4" onclick="openModal(${x.carId})" >Add Review</button>`;
                }
                 html+=`</div>
                </div>
            </div>`;
        }
        document.getElementById("cars").innerHTML=html;
    }
    function openModal(carId)
    {
        document.getElementById("carId").value=carId;
    }
    async function addReview()
    {
        var carId=document.getElementById("carId").value;
        var feedback=document.getElementById('feedback').value;
        var rating=document.getElementById('rating').value;

        var res=await fetch('/user/addreview',{
            method:'POST',
            headers:{'Content-Type':'application/json'},
            body:JSON.stringify({
                carId:carId,
                feedback:feedback,
                rating:rating
            })
        })
        res=await res.json();
        if(res.error)
        {
            Qual.errordb("Error",res.message);
        }
        else
        {
            Qual.successdb("Success", res.message);
            setTimeout((c)=> {
                    goback();
                },2000 //time in milliseconds
            );
        }
    }
    async function goback()
    {
        window.location.href='/user/mycars';
    }

</script>

</body>
</html>